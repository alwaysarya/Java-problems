import java.util.*;

public class Subseqtargsum {
    public static void main(String[] args){
        int[] arr={1,2,1};
        find(arr,0,0,2,new ArrayList<>());
    }

    static void find(int[] arr,int index,int sum,int target,List<Integer>list){
        if(index== arr.length){
            if(sum== target){
                System.out.println(list);
            }
            return;
        }

        //taking element
        list.add(arr[index]);
        find(arr, index+1, sum+arr[index], target, list);

        //backtracking
        list.remove(list.size()-1);

        //do not take
        find(arr, index+1, sum, target, list);
    }
}

